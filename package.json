{
  "name": "career-guidance-ai",
  "version": "1.0.1",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "smoke": "tsx src/tests/smoke-test.ts",
    "typecheck": "tsc --noEmit",
    "validate-config": "tsx scripts/validate-config.ts",
    "eval-fixtures": "tsx scripts/eval-fixtures.ts",
    "eval": "tsx scripts/eval-fixtures.ts",
    "golden": "tsx src/tests/golden-path.test.ts",
    "recovery": "tsx src/tests/recovery.test.ts",
    "journeys": "tsx src/tests/journeys.test.ts",
    "determinism": "tsx src/tests/determinism.test.ts",
    "continuity": "tsx src/tests/continuity.test.ts",
    "check": "npm run typecheck && npm run validate-config && npm run golden && npm run recovery && npm run journeys && npm run determinism && npm run continuity && npm run smoke && npm run eval-fixtures"
  },
  "keywords": [
    "career-guidance",
    "langgraph",
    "ai-agent"
  ],
  "author": "prabhusana",
  "license": "ISC",
  "description": "Career Guidance Assistant - LangGraph TypeScript conversational AI agent",
  "dependencies": {
    "@langchain/community": "^1.1.25",
    "@langchain/core": "^1.1.36",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/langgraph": "^1.2.6",
    "@types/compression": "^1.8.1",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "faiss-node": "^0.5.1",
    "pdfkit": "^0.18.0",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
