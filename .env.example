# LLM (required for chat)
# Provider routing:
# - Set LLM_PROVIDER_SEQUENCE to try providers in order.
# - Or set LLM_PROVIDER=groq or google to force one provider when sequence is unset.
LLM_PROVIDER_SEQUENCE=groq,google
# LLM_PROVIDER=groq

# Groq (OpenAI-compatible API routing)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_CANDIDATES=qwen/qwen3-32b,llama-3.3-70b-versatile

# Google / Gemini fallback
GEMINI_API_KEY=
GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODEL=gemini-1.5-flash
# GEMINI_MODEL_CANDIDATES=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-flash-latest,gemini-2.0-flash

# Server (Render sets PORT automatically)
PORT=3000

# O*NET Web Services v2: use your API key as ONET_USERNAME (see src/services/onet.ts)
ONET_API_KEY=
ONET_USERNAME=
ONET_PASSWORD=

BLS_API_KEY=
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Optional: LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=career-guidance-ai

# Optional: query embeddings for RAG chunk search (defaults to localhost; unset on cloud if no Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
