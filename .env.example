# Required for chat (Gemini)
GOOGLE_API_KEY=

# Server (Render sets PORT automatically)
PORT=3000

# O*NET Web Services v2: use your API key as ONET_USERNAME (see src/services/onet.ts)
ONET_USERNAME=
# Optional legacy field; live O*NET works with ONET_USERNAME alone
ONET_PASSWORD=

BLS_API_KEY=
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Optional: LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=career-guidance-ai

# Optional: query embeddings for RAG chunk search (defaults to localhost; unset on cloud if no Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
