{
  "version": "1.0",
  "default_phase": "orientation",
  "phases": {
    "orientation": {
      "display_name": "Getting to Know You",
      "purpose": "Collect the user's professional background and determine their session goal.",
      "allowed_targets": ["exploration_career", "exploration_role_targeting"],
      "conditions": {
        "exploration_career": "all_required_complete AND session_goal == explore_options",
        "exploration_role_targeting": "all_required_complete AND session_goal == pursue_specific_role"
      },
      "max_turns": 8,
      "auto_advance": true,
      "order": 1
    },
    "exploration_career": {
      "display_name": "Exploring Career Directions",
      "purpose": "Discover the user's interests and surface 2-4 candidate career directions.",
      "allowed_targets": ["exploration_role_targeting", "planning"],
      "conditions": {
        "exploration_role_targeting": "user_names_specific_target",
        "planning": "candidate_directions.length >= 2 AND user_requests_advance"
      },
      "max_turns": 15,
      "auto_advance": false,
      "order": 2
    },
    "exploration_role_targeting": {
      "display_name": "Assessing Your Skills",
      "purpose": "Confirm the target role and collect skill self-assessments against O*NET requirements.",
      "allowed_targets": ["planning"],
      "conditions": {
        "planning": "skills_assessed_percentage >= 60"
      },
      "max_turns": 20,
      "auto_advance": true,
      "order": 3
    },
    "planning": {
      "display_name": "Building Your Career Plan",
      "purpose": "Synthesize gap analysis into a 6-component action plan and generate the exportable report.",
      "allowed_targets": [],
      "conditions": {},
      "max_turns": 10,
      "auto_advance": false,
      "order": 4
    }
  }
}
